<Window
    x:Class="MegaPDF.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MegaPDF.App">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Single slim toolbar — the app's entire command surface (SDD §2.2) -->
        <Grid Grid.Row="0" Padding="8,4" ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                <Button Command="{x:Bind ViewModel.OpenCommand}" AccessKey="O">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8E5;" FontSize="16" />
                        <TextBlock Text="Open" />
                    </StackPanel>
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="O" />
                    </Button.KeyboardAccelerators>
                </Button>

                <Button Command="{x:Bind ViewModel.SaveCommand}" AccessKey="S">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74E;" FontSize="16" />
                        <TextBlock Text="{x:Bind ViewModel.SaveButtonLabel, Mode=OneWay}" />
                    </StackPanel>
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="S" />
                    </Button.KeyboardAccelerators>
                </Button>

                <Button Command="{x:Bind ViewModel.SaveAsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE792;" FontSize="16" />
                        <TextBlock Text="Save As" />
                    </StackPanel>
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control,Shift" Key="S" />
                    </Button.KeyboardAccelerators>
                </Button>

                <AppBarSeparator />

                <Button Command="{x:Bind ViewModel.UndoCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7A7;" FontSize="16" />
                        <TextBlock Text="Undo" />
                    </StackPanel>
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Z" />
                    </Button.KeyboardAccelerators>
                </Button>

                <Button Command="{x:Bind ViewModel.RedoCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7A6;" FontSize="16" />
                        <TextBlock Text="Redo" />
                    </StackPanel>
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Y" />
                    </Button.KeyboardAccelerators>
                </Button>

                <AppBarSeparator />

                <Button>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEE56;" FontSize="16" />
                        <TextBlock Text="Signatures" />
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout x:Name="SignaturesFlyout" Placement="BottomEdgeAlignedLeft">
                            <StackPanel Spacing="8" MinWidth="260">
                                <TextBlock Text="Your signatures" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Signatures}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:SignatureItem">
                                            <Button
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Margin="0,2"
                                                Click="OnSignatureClicked">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Border Background="White" CornerRadius="4" Padding="4">
                                                        <Image Source="{x:Bind Thumbnail}" Height="28" MaxWidth="110" Stretch="Uniform" />
                                                    </Border>
                                                    <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <Button.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="Remove from library" Click="OnRemoveSignatureClicked">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE74D;" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                    </MenuFlyout>
                                                </Button.ContextFlyout>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Click="OnAddSignatureFromImageClicked" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xEB9F;" FontSize="14" />
                                        <TextBlock Text="Add from image…" />
                                    </StackPanel>
                                </Button>
                                <Button Click="OnTypeSignatureClicked" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE70F;" FontSize="14" />
                                        <TextBlock Text="Type signature…" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Command="{x:Bind ViewModel.ZoomOutCommand}" Content="&#xE738;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" ToolTipService.ToolTip="Zoom out" />
                <TextBlock
                    Text="{x:Bind ViewModel.ZoomLabel, Mode=OneWay}"
                    VerticalAlignment="Center"
                    MinWidth="42"
                    TextAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Button Command="{x:Bind ViewModel.ZoomInCommand}" Content="&#xE710;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" ToolTipService.ToolTip="Zoom in" />
                <TextBlock
                    Text="{x:Bind ViewModel.PageIndicator, Mode=OneWay}"
                    VerticalAlignment="Center"
                    Margin="8,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Button Content="&#xE713;" FontFamily="{StaticResource SymbolThemeFontFamily}" ToolTipService.ToolTip="Settings">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <TextBlock Text="Settings coming soon." />
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Document area: empty-state drop zone until a document is open (SDD §2.2) -->
        <Grid
            Grid.Row="1"
            AllowDrop="True"
            DragOver="OnDocumentAreaDragOver"
            Drop="OnDocumentAreaDrop">

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}">
                <FontIcon Glyph="&#xE8A5;" FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    Text="Drag a PDF here, or click Open"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />

                <StackPanel Spacing="2" Margin="0,20,0,0" Visibility="{x:Bind ViewModel.RecentDocumentsVisibility, Mode=OneWay}">
                    <TextBlock
                        Text="RECENT"
                        FontSize="11"
                        CharacterSpacing="80"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.RecentDocuments}" HorizontalAlignment="Center">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:RecentDocument">
                                <HyperlinkButton Click="OnRecentDocumentClicked" HorizontalAlignment="Center" ToolTipService.ToolTip="{x:Bind Path}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8A5;" FontSize="13" />
                                        <TextBlock Text="{x:Bind Name}" />
                                    </StackPanel>
                                </HyperlinkButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <ScrollViewer
                x:Name="PagesScroll"
                Visibility="{x:Bind ViewModel.DocumentVisibility, Mode=OneWay}"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                ViewChanged="OnPagesScrollViewChanged">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Pages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="16" Padding="24" HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:PageView">
                            <local:PageCanvas
                                Width="{x:Bind Width}"
                                Height="{x:Bind Height}"
                                Background="White"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Tapped="OnPageTapped"
                                PointerMoved="OnPagePointerMoved"
                                PointerExited="OnPagePointerExited">
                                <Image Source="{x:Bind Source}" Stretch="Uniform" />
                            </local:PageCanvas>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <InfoBar
                IsOpen="{x:Bind ViewModel.IsFontNoticeOpen, Mode=TwoWay}"
                Severity="Informational"
                Message="This document's font isn't available, so a similar one was used."
                IsClosable="True"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="24" />

            <InfoBar
                Visibility="{x:Bind ViewModel.PlacementHintVisibility, Mode=OneWay}"
                IsOpen="True"
                Severity="Informational"
                Message="{x:Bind ViewModel.PlacementHint, Mode=OneWay}"
                CloseButtonClick="OnCancelPlacementClicked"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="24,12" />

            <!-- Offscreen host for rendering typed signatures (Segoe Script → bitmap). -->
            <Border x:Name="TypedSignatureHost" Opacity="0" IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock x:Name="TypedSignatureText" FontFamily="Segoe Script" FontSize="64" Foreground="Black" Padding="16,8" />
            </Border>
        </Grid>
    </Grid>
</Window>
